{
  "agents": {
    "defaults": {
      "model": "ollama/qwen3.5",
      "maxConcurrent": 2,
      "subagents": {
        "maxConcurrent": 1
      }
    }
  },
  "memory": {
    "strategy": "hybrid",
    "maxSizeMB": 200
  },
  "tools": {
    "browser": false,
    "docker": false,
    "exec": true,
    "web-search": true,
    "web-fetch": true,
    "message": true,
    "image": true,
    "tts": true
  },
  "channels": {
    "telegram": {
      "enabled": true
    },
    "discord": {
      "enabled": false
    },
    "slack": {
      "enabled": false
    }
  },
  "models": {
    "primary": "ollama/qwen3.5",
    "fallback": [
      "ollama/llama3:8b",
      "ollama/mistral:7b",
      "openai/gpt-4"
    ],
    "cloudEnabled": true
  }
}
